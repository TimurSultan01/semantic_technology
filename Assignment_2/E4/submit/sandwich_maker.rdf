<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/sandwich#"
     xml:base="http://example.org/sandwich"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/sandwich">
        <rdfs:comment xml:lang="en">Ontology for Exercise 4. It models sandwiches, sandwich ingredients, ingredient categories, the hasIngredient relation and its inverse isIngredientOf. The ontology is serialized in RDF/XML for Protégé.</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/sandwich#hasIngredient -->

    <owl:ObjectProperty rdf:about="http://example.org/sandwich#hasIngredient">
        <owl:inverseOf rdf:resource="http://example.org/sandwich#isIngredientOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdfs:range rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
        <rdfs:comment xml:lang="en">hasIngredient links sandwiches to their ingredients. It is not functional because a sandwich has several ingredients. It is not inverse-functional because the same ingredient can occur in several sandwiches. It is not transitive because an ingredient of an ingredient should not automatically become an ingredient of the sandwich. It is not symmetric because if a sandwich has an ingredient, the ingredient does not have the sandwich as ingredient. Therefore the appropriate characteristics selected here are asymmetric and irreflexive.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://example.org/sandwich#isIngredientOf -->

    <owl:ObjectProperty rdf:about="http://example.org/sandwich#isIngredientOf">
        <rdfs:domain rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
        <rdfs:range rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdfs:comment xml:lang="en">Inverse property of hasIngredient: an ingredient isIngredientOf a sandwich.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/sandwich#Bread -->

    <owl:Class rdf:about="http://example.org/sandwich#Bread">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
    </owl:Class>
    


    <!-- http://example.org/sandwich#Cheese -->

    <owl:Class rdf:about="http://example.org/sandwich#Cheese">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
    </owl:Class>
    


    <!-- http://example.org/sandwich#Fish -->

    <owl:Class rdf:about="http://example.org/sandwich#Fish">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
    </owl:Class>
    


    <!-- http://example.org/sandwich#Meat -->

    <owl:Class rdf:about="http://example.org/sandwich#Meat">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
    </owl:Class>
    


    <!-- http://example.org/sandwich#Sandwich -->

    <owl:Class rdf:about="http://example.org/sandwich#Sandwich">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sandwich#hasIngredient"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/sandwich#Sauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sandwich#hasIngredient"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://example.org/sandwich#SandwichIngredient"/>
                            <owl:Class>
                                <owl:complementOf rdf:resource="http://example.org/sandwich#Bread"/>
                            </owl:Class>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sandwich#hasIngredient"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/sandwich#Bread"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A sandwich. Every sandwich must have exactly two bread ingredients, at least two non-bread ingredients, and at least one sauce.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/sandwich#SandwichIngredient -->

    <owl:Class rdf:about="http://example.org/sandwich#SandwichIngredient">
        <rdfs:comment xml:lang="en">General class for ingredients that can be used in sandwiches.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/sandwich#Sauce -->

    <owl:Class rdf:about="http://example.org/sandwich#Sauce">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
    </owl:Class>
    


    <!-- http://example.org/sandwich#Vegetable -->

    <owl:Class rdf:about="http://example.org/sandwich#Vegetable">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#SandwichIngredient"/>
    </owl:Class>
    


    <!-- http://example.org/sandwich#VegetableOnlySandwich -->

    <owl:Class rdf:about="http://example.org/sandwich#VegetableOnlySandwich">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#WithoutFishSandwich"/>
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#WithoutMeatSandwich"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sandwich#hasIngredient"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://example.org/sandwich#Bread"/>
                            <rdf:Description rdf:about="http://example.org/sandwich#Sauce"/>
                            <rdf:Description rdf:about="http://example.org/sandwich#Vegetable"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A sandwich category for sandwiches whose ingredients are restricted to bread, sauce and vegetables. Therefore this category is also without meat and without fish.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/sandwich#WithoutFishSandwich -->

    <owl:Class rdf:about="http://example.org/sandwich#WithoutFishSandwich">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sandwich#hasIngredient"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://example.org/sandwich#Fish"/>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A sandwich category for sandwiches that must not have any fish ingredient.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/sandwich#WithoutMeatSandwich -->

    <owl:Class rdf:about="http://example.org/sandwich#WithoutMeatSandwich">
        <rdfs:subClassOf rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/sandwich#hasIngredient"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://example.org/sandwich#Meat"/>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A sandwich category for sandwiches that must not have any meat ingredient.</rdfs:comment>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/sandwich#Avocado -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Avocado">
        <rdf:type rdf:resource="http://example.org/sandwich#Vegetable"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Baguette -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Baguette">
        <rdf:type rdf:resource="http://example.org/sandwich#Bread"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Basil -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Basil">
        <rdf:type rdf:resource="http://example.org/sandwich#Vegetable"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Ciabatta -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Ciabatta">
        <rdf:type rdf:resource="http://example.org/sandwich#Bread"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Cucumber -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Cucumber">
        <rdf:type rdf:resource="http://example.org/sandwich#Vegetable"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#GreenSalad -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#GreenSalad">
        <rdf:type rdf:resource="http://example.org/sandwich#Vegetable"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#ItalianSandwich -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#ItalianSandwich">
        <rdf:type rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdf:type rdf:resource="http://example.org/sandwich#WithoutFishSandwich"/>
        <rdf:type rdf:resource="http://example.org/sandwich#WithoutMeatSandwich"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Baguette"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Basil"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Ciabatta"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Mozzarella"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#TomatoSauce"/>
        <rdfs:comment xml:lang="en">Italian Sandwich has ciabatta, baguette, tomato sauce, basil and mozzarella. It is without meat and without fish.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Ketchup -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Ketchup">
        <rdf:type rdf:resource="http://example.org/sandwich#Sauce"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Mayonnaise -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Mayonnaise">
        <rdf:type rdf:resource="http://example.org/sandwich#Sauce"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Mozzarella -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Mozzarella">
        <rdf:type rdf:resource="http://example.org/sandwich#Cheese"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Prosciutto -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Prosciutto">
        <rdf:type rdf:resource="http://example.org/sandwich#Meat"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#ProsciuttoSandwich -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#ProsciuttoSandwich">
        <rdf:type rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdf:type rdf:resource="http://example.org/sandwich#WithoutFishSandwich"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Baguette"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Cucumber"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Ketchup"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Prosciutto"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#WhiteBread"/>
        <rdfs:comment xml:lang="en">Prosciutto Sandwich has white bread, baguette, ketchup, prosciutto and cucumber. It is without fish, but not without meat.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Salami -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Salami">
        <rdf:type rdf:resource="http://example.org/sandwich#Meat"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Salmon -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Salmon">
        <rdf:type rdf:resource="http://example.org/sandwich#Fish"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#SalmonSandwich -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#SalmonSandwich">
        <rdf:type rdf:resource="http://example.org/sandwich#Sandwich"/>
        <rdf:type rdf:resource="http://example.org/sandwich#WithoutMeatSandwich"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Avocado"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Ciabatta"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Mayonnaise"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#Salmon"/>
        <hasIngredient rdf:resource="http://example.org/sandwich#WholeWheatBread"/>
        <rdfs:comment xml:lang="en">Salmon Sandwich has whole-wheat bread, ciabatta, mayonnaise, salmon and avocado. It is without meat, but not without fish.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#TomatoSauce -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#TomatoSauce">
        <rdf:type rdf:resource="http://example.org/sandwich#Sauce"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#Tuna -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#Tuna">
        <rdf:type rdf:resource="http://example.org/sandwich#Fish"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#WhiteBread -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#WhiteBread">
        <rdf:type rdf:resource="http://example.org/sandwich#Bread"/>
    </owl:NamedIndividual>
    


    <!-- http://example.org/sandwich#WholeWheatBread -->

    <owl:NamedIndividual rdf:about="http://example.org/sandwich#WholeWheatBread">
        <rdf:type rdf:resource="http://example.org/sandwich#Bread"/>
    </owl:NamedIndividual>
    


