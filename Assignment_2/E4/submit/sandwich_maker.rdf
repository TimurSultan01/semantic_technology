            <rdf:Description rdf:about="http://example.org/sandwich#Ketchup"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Mayonnaise"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Mozzarella"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Prosciutto"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Salami"/>
