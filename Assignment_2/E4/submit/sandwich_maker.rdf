    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/sandwich#Bread"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Cheese"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Fish"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Meat"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Sauce"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Vegetable"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDifferent"/>
        <owl:distinctMembers rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/sandwich#Avocado"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Baguette"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Basil"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Ciabatta"/>
            <rdf:Description rdf:about="http://example.org/sandwich#Cucumber"/>
